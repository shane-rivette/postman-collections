        {
          "name": "ADD User to Account",
          "id": "f60fa152-542a-40c5-88f9-d7d484575a09",
          "protocolProfileBehavior": {
            "disableBodyPruning": true
          },
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "X-Auth-Token",
                "value": "{{token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation (\n      $userEmail: String!\n){\n  account {\n    addUserToAccount(\n      input: {\n        email: $userEmail\n      }\n    ) {\n      account {\n        accountInfo {\n          name\n        }\n      }\n    }\n  }\n}",
                "variables": "{\"userEmail\": \"test@bigcommerce.com\"}"
              }
