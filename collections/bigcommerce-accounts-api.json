            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "query {\n  account {\n    id\n    stores {\n      edges {\n        node {\n          id\n          name\n          storeHash\n          users {\n            edges {\n              node {\n                id\n                email\n                firstName\n                lastName\n                locale\n                lastLoginAt\n                permissions\n                status\n                updatedAt\n                apps {\n                  edges {\n                    node {\n                      id\n                      name\n                    }\n                  }\n                }\n              }\n            }\n          }\n          apps {\n            edges {\n              node {\n                id\n                name\n              }\n            }\n          }\n        }\n      }\n    }\n  }\n}",
                "variables": ""
