                "query": "mutation (\n      $userEmail: String!,\n      $userFirst: String!,\n      $userLast: String!,\n      $password: String!\n){\n  user {\n    createUserWithPassword(\n      input: {\n        email: $userEmail, \n        firstName: $userFirst, \n        lastName: $userLast,  \n        locale: \"en-US\", \n        password: $password, \n        passwordConfirmation: $password\n      }\n    ) {\n        user {\n            id\n            email\n            firstName\n            lastName\n            locale\n        }\n    }\n  }\n}",
                "variables": "{\n    \"userEmail\": \"test+anything1@bigcommerce.com\",\n    \"userFirst\": \"API\",\n    \"userLast\": \"Test\",\n    \"password\": \"Teting123!\"\n}"
              }
