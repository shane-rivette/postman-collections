    {
      "name": "Retrieve First 250 Products with Variants Copy",
      "event": [
        {
          "listen": "test",
          "script": {
            "id": "247139d1-cbd2-422d-aec0-d05b4d599cfd",
            "exec": [
              "// Initialize environment variables",
              "pm.environment.set(\"product-id\", \"\");",
              "pm.environment.set(\"line-item-id\", \"\");",
              "pm.environment.set(\"cart-id\", \"\");",
              "pm.environment.set(\"variant-id\", \"\");",
              "pm.environment.set(\"shipping-option-id\", \"\");",
              "pm.environment.set(\"consignment-id\", \"\");",
              "pm.environment.set(\"order-id\", \"\");",
              "",
              "function setProductEnvVars(product, variantIndex) {",
              "            postman.setEnvironmentVariable(\"product-id\", product.id);",
              "            postman.setEnvironmentVariable(\"variant-id\", product.variants[variantIndex].id);",
              "            // Look for the prsence of options",
              "            if (product.option_set_id) {",
              "                var optionValues = product.variants[variantIndex].option_values;",
              "                for (var v = 0; v < optionValues.length; v++){",
              "                    postman.setEnvironmentVariable(\"option-id-\"+v, optionValues[v].option_id);",
              "                    postman.setEnvironmentVariable(\"option-value-id-\"+v, optionValues[v].id);",
              "                }",
              "            }",
              "}",
              "",
              "",
              "",
              "try {",
              "var count = pm.response.json().meta.pagination.count;",
              "var products = pm.response.json().data;",
              "//Only search this page of results",
              "if (count > 250) {count = 250;}",
              "",
              "// Find a product in stock, or that doesn't track inventory",
              "    for (var i = 0; i < count; i ++){",
              "",
              "        if (products[i].inventory_tracking === \"none\") {",
              "            setProductEnvVars(products[i], 0);",
              "            break;",
              "        }",
              "",
              "        if (postman.getEnvironmentVariable(\"product-id\") === \"\") {",
              "            if (products[i].inventory_tracking === \"product\" && products[i].inventory_level > 0) {",
              "                    setProductEnvVars(products[i], 0);",
              "                    break;",
              "               }",
              "                ",
              "                   ",
              "        }",
              "",
              "        if (postman.getEnvironmentVariable(\"product-id\") === \"\"){",
              "            if (products[i].inventory_tracking === \"variant\") {",
              "                    console.log(\"found a product with variant tracking\");",
              "                    for (var v = 0; v < products[i].variants.length; v++){",
              "                        if (products[i].variants[v].inventory_level > 0) {",
              "                            console.log(\"cycling through variants to check inventory\");",
              "                            setProductEnvVars(products[i], v);",
              "                            console.log(\"product ID is \"+postman.getEnvironmentVariable(\"product-id\"));",
              "                            break;",
              "                    }",
              "                }",
              "            }",
              "",
              "        }",
              "    if (postman.getEnvironmentVariable(\"product-id\") !== \"\"){break;}",
              "    }",
              "}",
              "catch(err) {",
              "    console.log(\"Error: \"+err);",
              "}",
              "pm.test(\"Found a product with no inventory tracking\", function(){",
              "   pm.expect(postman.getEnvironmentVariable(\"product-id\")).to.be.a('string').that.is.not.empty;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "id": "5c429981-dad5-471b-9f5f-edfda95c3a4d",
      "protocolProfileBehavior": {
        "disableBodyPruning": true
      },
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-Auth-Client",
            "value": "{{client-id}}"
          },
          {
            "key": "X-Auth-Token",
            "value": "{{token}}"
          },
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "https://api.bigcommerce.com/stores/{{store-hash}}/v3/catalog/products?limit=250&include=variants",
          "protocol": "https",
          "host": [
            "api",
            "bigcommerce",
            "com"
          ],
          "path": [
            "stores",
            "{{store-hash}}",
            "v3",
            "catalog",
            "products"
          ],
          "query": [
            {
              "key": "limit",
              "value": "250"
            },
            {
              "key": "include",
              "value": "variants"
            }
          ]
        },
        "description": "Shows full product data with a single GET request"
      },
