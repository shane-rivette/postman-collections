        {
          "name": "Create a Consignment with Nested Objects in Custom Fields",
          "event": [
            {
              "listen": "test",
              "script": {
                "id": "5eb6ab83-6d29-47db-b95f-00bbf42f3f62",
                "exec": [
                  "jsonData = pm.response.json();",
                  "if(pm.test(\"Consignment ID generated\", function() {",
                  "    pm.expect(jsonData.consignments[0].id).to.be.a('string');",
                  "})){",
                  "    postman.setEnvironmentVariable(\"consignment-id\", jsonData.consignments[0].id);",
                  "    postman.setEnvironmentVariable(\"shipping-option-id\", jsonData.consignments[0].availableShippingOptions[0].id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "id": "a5bbefcb-a046-4287-8c58-fefd608a8f94",
                "exec": [
                  "const nestedObj = JSON.stringify({",
                  "\t      \t\tsome: \"object\",",
                  "\t      \t\t\tw: \"properties\",",
                  "\t      \t\t\tthis_one: {",
                  "\t      \t\t\t\tis: \"nested\"",
                  "\t      \t\t\t\t",
                  "\t      \t\t\t}",
                  "\t      \t\t})",
                  "",
                  "const escapedObj = nestedObj.replace(/\"/g, \"\\\\\\\"\")\t      ",
                  "console.log('Nested Object', escapedObj)",
                  "\t      \t\t",
                  "pm.environment.set('nested-obj', escapedObj)"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "id": "98b09cb5-fa33-4db9-a29a-622a865fc89a",
          "protocolProfileBehavior": {
            "disableBodyPruning": true
          },
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "[\n  {\n    \"shippingAddress\": {\n      \"firstName\": \"John\",\n      \"lastName\": \"Doe\",\n      \"email\": \"shippingaddress@example.org\",\n      \"company\": \"\",\n      \"address1\": \"11305 Four Points Dr\",\n      \"address2\": \"Suite 300\",\n      \"city\": \"Austin\",\n      \"stateOrProvince\": \"Texas\",\n      \"stateOrProvinceCode\": \"TX\",\n      \"countryCode\": \"US\",\n      \"postalCode\": \"78726\",\n      \"phone\": \"5128654500\",\n      \"customFields\": [{\n      \t\t\"fieldId\": \"field_28\",\n      \t\t\"fieldValue\": \"{{nested-obj}}\"\n      \t}]\n    },\n    \"lineItems\": [\n      {\n        \"itemId\": \"{{line-item-id}}\",\n        \"quantity\": 1\n      }\n    ]\n  }\n]"
            },
            "url": {
              "raw": "https://{{domain}}/api/storefront/checkouts/{{cart-id}}/consignments?include=consignments.availableShippingOptions",
              "protocol": "https",
              "host": [
                "{{domain}}"
