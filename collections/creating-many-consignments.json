    {
      "name": "Create a Consignment (Shipping Address)",
      "event": [
        {
          "listen": "test",
          "script": {
            "id": "7d53e485-d1da-4e0a-b11d-822b7083580e",
            "exec": [
              "var jsonData = pm.response.json();",
              "",
              "pm.test(\"Consignments has length\", function (){",
              "    pm.expect(jsonData.data.consignments.length).to.be.greaterThan(0)",
              "})",
              "",
              "console.log('Current number of consignments: ', jsonData.data.consignments.length)",
              "",
              "const max = parseInt(pm.collectionVariables.get('max-quantity'))",
              "",
              "const iterator = parseInt(pm.collectionVariables.get('max-iterator'))",
              "",
              "pm.collectionVariables.set('max-iterator', iterator + 1)",
              "",
              "if(jsonData.data.consignments.length < max) postman.setNextRequest('Create a Consignment (Shipping Address)') ",
              ""
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "id": "f1089982-5287-4de7-9270-c057ace1de0f",
            "exec": [
              "const consignments = []",
              "",
              "const max = parseInt(pm.collectionVariables.get('max-quantity'))",
              "",
              "for(let i = 1; i < max; i++) {",
              "    consignments.push(  {",
              "    \"shipping_address\": {",
              "      \"first_name\": `Patrick ${i}`,",
              "      \"last_name\": \"Puente\",",
              "      \"email\": \"patrick.puente@bigcommerce.com\",",
              "      \"company\": \"\",",
              "      \"address1\": \"11305 Four Points Dr #300\",",
              "      \"address2\": \"\",",
              "      \"city\": \"Austin\",",
              "      \"state_or_province\": \"Texas\",",
              "      \"state_or_province_code\": \"TX\",",
              "      \"country_code\": \"US\",",
              "      \"postal_code\": \"78726\",",
              "      \"phone\": \"5128654500\"",
              "    },",
              "    \"line_items\": [",
              "      {",
              "        \"item_id\": pm.environment.get('line-item-id'),",
              "        \"quantity\": 1",
              "      }",
              "    ]",
              "  })",
              "}",
              "",
              "pm.collectionVariables.set('consignments', JSON.stringify(consignments))"
            ],
            "type": "text/javascript"
          }
        }
      ],
