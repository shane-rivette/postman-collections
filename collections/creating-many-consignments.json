    {
      "name": "Create a Cart",
      "event": [
        {
          "listen": "test",
          "script": {
            "id": "c16de063-52a6-4207-8ef3-71263f0d85ee",
            "exec": [
              "jsonData = pm.response.json();",
              "if(pm.test(\"Cart ID generated\", function() {",
              "    pm.expect(jsonData.data.id).to.be.a('string');",
              "})){",
              "    postman.setEnvironmentVariable(\"cart-id\", jsonData.data.id);",
              "    postman.setEnvironmentVariable(\"line-item-id\", jsonData.data.line_items.physical_items[0].id);",
              "}"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "id": "ae53ddd2-f2d8-48ff-9bb0-eb279834deae",
            "exec": [
              "",
              "function countOptions(){",
              "// Assuming no product has > 20 options",
              "    for (var i = 0; i <= 20; i++){",
              "        console.log(postman.getEnvironmentVariable(envVar));",
              "        var envVar = \"option-id-\"+i;",
              "        if (!postman.getEnvironmentVariable(envVar)){",
              "            return i;",
              "        }",
              "    }",
              "}",
              "",
              "function buildOptionSelections(count){",
              "    var optionSelections = [];",
              "    for (var i = 0; i < count; i++){",
              "        var optionEnvVar = \"option-id-\"+i;",
              "        var optionValueEnvVar = \"option-value-id-\"+i;",
              "        optionSelections[i] = {option_id:postman.getEnvironmentVariable(optionEnvVar), option_value:postman.getEnvironmentVariable(optionValueEnvVar)};",
              "    }",
              "    pm.environment.set(\"option-selections\", JSON.stringify(optionSelections));",
              "}",
              "",
              "buildOptionSelections(countOptions());"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "id": "0d43ade9-0ae7-4db4-8e0e-1e88c42918b5",
      "protocolProfileBehavior": {
        "disableBodyPruning": true
      },
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "X-Auth-Client",
            "value": "{{client-id}}"
          },
          {
            "key": "X-Auth-Token",
            "value": "{{token}}"
          },
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"customer_id\": {{customer-id}},\r\n  \"line_items\": [\r\n    {\r\n      \"quantity\": {{max-quantity}},\r\n      \"product_id\": {{product-id}},\r\n      \"variant_id\": {{variant-id}},\r\n      \"option_selections\": {{option-selections}}\r\n    }\r\n  ]\r\n}"
        },
        "url": {
          "raw": "https://api.bigcommerce.com/stores/{{store-hash}}/v3/carts",
          "protocol": "https",
          "host": [
            "api",
            "bigcommerce",
            "com"
          ],
          "path": [
            "stores",
            "{{store-hash}}",
            "v3",
            "carts"
          ]
        },
        "description": "Create a cart with a coupon code and a gift certificate.\n\nUpdate the following IDs as needed:\n* Product\n* Variant\n* Option\n* Option Value\n\nUpdate the \"coupons\" array as needed."
      },
      "response": [],
