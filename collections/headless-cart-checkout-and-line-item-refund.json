    {
      "name": "#11 Create Refund Quote",
      "event": [
        {
          "listen": "test",
          "script": {
            "id": "7e994607-ff30-4a66-a5dc-859dc867edca",
            "exec": [
              "pm.test('Response is not an error', () => {",
              "    pm.response.to.not.be.error",
              "    pm.response.to.not.have.jsonBody(\"errors\")",
              "})",
              "",
              "pm.test('Response is JSON with data', () => {",
              "    pm.response.to.have.jsonBody(\"data\")",
              "})",
              "",
              "const payments = pm.response.json().data.refund_methods.find(payment => payment.find(method => method.provider_id !== 'storecredit'))",
              "",
              "pm.test('Found a refund_method with a sum of payment amounts that is a number', () => {",
              "    pm.expect(payments.reduce((amount, payment) => amount + payment.amount, 0)).to.be.a('number')",
              "})",
              "",
              "// Clear any previously stored collection variables",
              "pm.collectionVariables.unset('payments')",
              "// Store new collection variables",
              "pm.collectionVariables.set('payments', JSON.stringify(payments, null, 2))"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "id": "a0c016b2-a233-4f5e-8a85-4f2e73cc44e4",
