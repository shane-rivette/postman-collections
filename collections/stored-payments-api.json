    {
      "name": "Bulk Import Instruments",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let jsonData = pm.response.json();",
              "",
              "pm.test(\"Capture and store tokens\", function () {",
              "    // Check if the data property exists and is an array",
              "    pm.expect(jsonData.data).to.be.an('array');",
              "",
              "    // Loop through each object in the data array",
              "    jsonData.data.forEach((item, index) => {",
              "        // Check if the token property exists and is a string",
              "        pm.expect(item.token).to.be.a('string');",
              "",
              "        // Construct the variable name and store the token in the environment",
              "        let variableName = 'instrument-token-' + index;",
              "        pm.environment.set(variableName, item.token);",
              "    });",
              "});",
              ""
            ],
            "type": "text/javascript",
            "id": "d3da1ba7-5ae0-4b7b-b41e-f0dc83c81b4f"
          }
        }
