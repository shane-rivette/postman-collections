    {
      "name": "Create Instrument Access Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "if(pm.test(\"Instrument Access Token Generated\", function(){",
              "    pm.expect(jsonData.data.access_token).to.be.a('string');",
              "})){",
              "    postman.setEnvironmentVariable('instrument_access_token', jsonData.data.access_token);",
              "}"
            ],
            "type": "text/javascript",
            "id": "7075a073-05e4-444e-af40-8d935c57bd70"
          }
