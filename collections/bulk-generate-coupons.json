        "type": "text/javascript",
        "exec": [
          ""
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "api-token",
      "value": "BC_API_TOKEN",
      "type": "string"
    },
    {
      "key": "store-hash",
      "value": "BC_STORE_HASH",
      "type": "string"
    },
    {
      "key": "promotion-id",
      "value": "BC_PROMOTION_ID",
      "type": "string"
    },
    {
      "key": "code",
      "value": "LEAVE_BLANK"
