    {
      "name": "Create a Consignment (Shipping Address)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "if(pm.test(\"Consignment Created\", function (){",
              "    pm.expect(jsonData.data.consignments[0].id).to.be.a(\"string\").that.is.not.empty;",
              "})){",
              "    postman.setEnvironmentVariable(\"consignment-id\", jsonData.data.consignments[0].id);",
              "}",
              "",
              "if(pm.test(\"Shipping Options Available\", function(){",
              "    pm.expect(jsonData.data.consignments[0].available_shipping_options[0]).to.be.an(\"object\");",
              "})){",
              "    postman.setEnvironmentVariable(\"shipping-option-id\", jsonData.data.consignments[0].available_shipping_options[0].id);",
              "}"
            ],
            "type": "text/javascript",
            "id": "b7426416-be87-42b5-bf42-eb33911a1def"
          }
        }
