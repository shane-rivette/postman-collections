    {
      "name": "Create a Cart",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "jsonData = pm.response.json();",
              "if(pm.test(\"Cart ID generated\", function() {",
              "    pm.expect(jsonData.data.id).to.be.a('string');",
              "})){",
              "    postman.setEnvironmentVariable(\"cart-id\", jsonData.data.id);",
              "    postman.setEnvironmentVariable(\"line-item-id\", jsonData.data.line_items.physical_items[0].id);",
              "}"
            ],
            "type": "text/javascript",
            "id": "cb419665-f8a9-4744-9435-e4971a87735d"
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "",
              "function countOptions(){",
              "// Assuming no product has > 20 options",
              "    for (var i = 0; i <= 20; i++){",
              "        console.log(postman.getEnvironmentVariable(envVar));",
              "        var envVar = \"option-id-\"+i;",
              "        if (!postman.getEnvironmentVariable(envVar)){",
              "            return i;",
              "        }",
              "    }",
              "}",
              "",
              "function buildOptionSelections(count){",
              "    var optionSelections = [];",
              "    for (var i = 0; i < count; i++){",
              "        var optionEnvVar = \"option-id-\"+i;",
              "        var optionValueEnvVar = \"option-value-id-\"+i;",
              "        optionSelections[i] = {option_id:postman.getEnvironmentVariable(optionEnvVar), option_value:postman.getEnvironmentVariable(optionValueEnvVar)};",
              "    }",
              "    pm.environment.set(\"option-selections\", JSON.stringify(optionSelections));",
              "}",
              "",
              "buildOptionSelections(countOptions());"
            ],
            "type": "text/javascript",
            "id": "00ed3364-f358-40e8-8b89-a113fb65f1e6"
          }
        }
      ],
      "id": "04d3b916-9af2-4341-88c9-d6c189749937",
