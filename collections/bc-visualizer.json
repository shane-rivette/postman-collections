      "name": "Retrieve all orders - Table View",
      "event": [
        {
          "listen": "test",
          "script": {
            "id": "abd52fe1-4ce6-4c6f-890f-45539b151a2f",
            "exec": [
              "// ",
              "// BigCommerce Postman - Template Structure (Orders)",
              "//",
              "",
              "const template = `",
              "    //Template style",
              "    <style type=\"text/css\">",
              "        .table-lg {font-size:14px; color:#333333; width:100%; border-width: 1px; border-color: #4e34c6; border-collapse: collapse;}",
              "        .table-lg th {font-size:18px; color: #fff; background-color:#4e34c6; border-width: 1px; padding: 8px; border-style: solid; border-color: #4e34c6; text-align:left;}",
              "        .table-lg tr {background-color: #ffffff;}",
              "        .table-lg td {font-size:14px; border-width: 1px; padding: 8px; border-style: solid; border-color: #4e34c6;}",
              "        .table-lg tr:hover {background-color:#f4f7f9;}",
              "    </style>",
              "    ",
              "    // HTML assets and structure",
              "    <table class=\"table-lg\" bgcolor=\"#FFFFFF\" border=\"1\">",
              "        <tr>",
              "            <th>Order No.</th>",
              "            <th>Customer</th>",
              "            <th>Date Created</th>",
              "            <th>Status</th>",
              "            <th>Total (Ex-Tax)</th>",
              "        </tr>",
              "        ",
              "        // Handlebar helper ",
              "        {{#each response}}",
              "            <tr>",
              "                <td>{{id}}</td>",
              "                <td>{{customer_id}}</td>",
              "                <td>{{date_created}}</td>",
              "                <td>{{status}}</td>",
              "                <td>{{total_ex_tax}}</td>",
              "            </tr>",
              "        {{/each}}",
              "    </table>",
              "`;",
              "",
              "// Template setup for visualizer ",
              "pm.visualizer.set(template, {",
              "    response: pm.response.json()",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
