      "name": "Create a new brand Copy",
      "event": [
        {
          "listen": "test",
          "script": {
            "id": "8cdf38e5-b2fc-41f6-a75f-05eea42b3ccf",
            "exec": [
              "const i = pm.environment.get('iterator')",
              "pm.environment.set('iterator', parseInt(i) + 1)",
              "",
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
