    {
      "name": "Retrieve a Charge (Stripe)",
      "event": [
        {
          "listen": "test",
          "script": {
            "id": "9b5a2bda-6c70-4d06-b29e-942d47bab77f",
            "exec": [
              "var jsonData = pm.response.json();",
              "if(pm.test(\"Response includes Stripe customer id\", function (){",
              "    pm.expect(jsonData.customer).to.be.a(\"string\").that.is.not.empty",
              "})){",
              "    postman.setEnvironmentVariable(\"stripe-customer-id\", jsonData.customer)",
              "}",
              "",
              "if(pm.test(\"Response includes Stripe payment method ID\", function (){",
              "    pm.expect(jsonData.payment_method).to.be.a(\"string\").that.is.not.empty",
              "})){",
              "    postman.setEnvironmentVariable(\"stripe-payment-method\", jsonData.payment_method)",
              "}",
              ""
            ],
            "type": "text/javascript"
          }
        }
      ],
