    {
      "name": "Create Subscription (Stripe)",
      "id": "36f748b7-f6c5-417b-bd5e-9c9950d79363",
      "protocolProfileBehavior": {
        "disableBodyPruning": true
      },
      "request": {
        "auth": {
          "type": "basic",
          "basic": [
            {
              "key": "password",
              "value": "",
              "type": "string"
            },
            {
              "key": "username",
              "value": "{{stripe-api-key}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "name": "Content-Type",
            "value": "application/x-www-form-urlencoded",
            "type": "text"
          }
        ],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "key": "customer",
              "value": "{{stripe-customer-id}}",
              "type": "text"
            },
            {
              "key": "items[0][plan]",
              "value": "{{stripe-subscription-plan}}",
              "type": "text"
            }
          ]
        },
        "url": {
          "raw": "https://api.stripe.com/v1/subscriptions",
          "protocol": "https",
