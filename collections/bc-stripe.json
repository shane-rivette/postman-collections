    {
      "name": "Get an Order Copy (BC)",
      "event": [
        {
          "listen": "test",
          "script": {
            "id": "f664a333-41c9-4d7c-975d-d0ccd6b70555",
            "exec": [
              "var jsonData = pm.response.json();",
              "if(pm.test(\"Response includes transaction id\", function (){",
              "    pm.expect(jsonData.payment_provider_id).to.be.a(\"string\").that.is.not.empty",
              "})){",
              "    postman.setEnvironmentVariable(\"transaction-id\", jsonData.payment_provider_id)",
              "}",
              ""
            ],
            "type": "text/javascript"
          }
        }
      ],
      "id": "129e0002-0eac-42b5-8ca4-3aa017c11bf3",
