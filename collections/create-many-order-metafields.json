      "name": "Create an Order Metafield Copy",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "id": "be9acc7f-43a5-4bfa-ada8-14f65b61f480",
            "exec": [
              "const iterator = parseInt(pm.collectionVariables.get('iterator'))",
              "",
              "pm.collectionVariables.set('iterator', iterator+1)"
