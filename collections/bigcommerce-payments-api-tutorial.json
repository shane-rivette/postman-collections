        {
          "name": "Create Payment Access Token",
          "id": "5b17726e-d118-4bde-9976-d7da33b20218",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-Auth-Client",
                "value": "{{client_id}}",
                "type": "text"
              },
              {
                "key": "X-Auth-Token",
                "value": "{{client_secret}}",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"order\": {\n    \"id\": {{order-id}}\n  }\n}"
            },
            "url": {
              "raw": "https://api.bigcommerce.com/stores/{{store_hash}}/v3/payments/access_tokens",
              "protocol": "https",
              "host": [
                "api",
                "bigcommerce",
                "com"
              ],
              "path": [
                "stores",
                "{{store_hash}}",
                "v3",
                "payments",
                "access_tokens"
              ]
            }
          },
          "response": [],
