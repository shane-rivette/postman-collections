  "item": [
    {
      "name": "Create new catalog download job",
      "event": [
        {
          "listen": "test",
          "script": {
            "id": "ec29d5c0-ef47-420c-8643-7329d8b39c56",
            "exec": [
              "var jsonData = JSON.parse(responseBody);\r",
              "if (jsonData.data && jsonData.data.id) {\r",
              "    postman.setEnvironmentVariable(\"job_id\", jsonData.data.id);\r",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "id": "2c6c4290-4fdd-4839-895a-576fc07f7959",
      "protocolProfileBehavior": {
        "disableBodyPruning": true
      },
      "request": {
        "method": "POST",
        "header": [
          {
            "disabled": true,
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Content-Type",
            "name": "Content-Type",
            "type": "text",
            "value": "application/json"
          },
          {
            "disabled": false,
            "key": "X-Auth-Client",
            "value": "{{client-id}}"
          },
          {
            "disabled": false,
            "key": "X-Auth-Token",
            "value": "{{token}}"
          },
          {
            "key": "Accept-Encoding",
            "type": "text",
            "value": "application/gzip"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"subresources\": [\n        \"variants\",\n        \"images\",\n        \"custom-fields\",\n        \"videos\",\n        \"bulk-pricing-rules\"\n    ]\n}"
        },
        "url": {
          "raw": "https://bulk-api.bigcommerce.tools/stores/{{store-hash}}/unstable/catalog-download/create-job",
          "protocol": "https",
          "host": [
            "bulk-api",
            "bigcommerce",
            "tools"
          ],
          "path": [
            "stores",
            "{{store-hash}}",
            "unstable",
            "catalog-download",
            "create-job"
          ],
          "query": [
            {
              "key": "Accept-Encoding",
              "value": "gzip",
              "disabled": true
            }
          ]
        },
        "description": "Creates a job for download an entire catalog. The body accepts which subresources you want downloaded together with the products. Selecting more subresources will make the job take longer."
      },
