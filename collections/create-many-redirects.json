{
  "info": {
    "_postman_id": "8fb574b8-c021-4d36-b0de-7a0a7fd02d70",
    "name": "Create Many Redirects",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "createdAt": "2021-06-08T15:54:24.000Z",
    "updatedAt": "2021-06-08T16:03:23.000Z",
    "lastUpdatedBy": "45334",
    "uid": "45334-8fb574b8-c021-4d36-b0de-7a0a7fd02d70"
  },
  "item": [
    {
      "name": "Create Redirects from Collection Variable",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "id": "514046be-7027-4308-9f4c-2272e8dfbb84",
            "exec": [
              "const iterator = parseInt(pm.collectionVariables.get('iterator'))",
              "const redirects = []",
              "for (let i = 0; i < 10; i++) {",
              "    redirects.push({",
              "       from_path: `/redirectme-${iterator+i}`,",
              "       site_id: 1000,",
              "       to: {",
              "           type: \"url\",",
              "           url: `/new-page-${iterator+i}`",
              "       } ",
              "    })",
              "}",
              "",
              "pm.collectionVariables.set('redirects-json', JSON.stringify(redirects))",
              "pm.collectionVariables.set('iterator', iterator+10)"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "id": "c9f62512-fd87-4efc-b480-3bd1dd453f48",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "id": "744aa1b9-8a30-495b-9c14-361f9ac80cd6",
      "protocolProfileBehavior": {
        "disableBodyPruning": true
      },
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "X-Auth-Client",
            "value": "{{client-id}}",
